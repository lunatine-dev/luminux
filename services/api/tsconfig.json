{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": ["node"],
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": "src",
        "paths": {
            "@constants/*": ["./src/constants/*"],
            "@services/*": ["./src/services/*"],
            "@utils/*": ["./src/utils/*"],
            "@core/*": ["./src/core/*"],
            "@defs/*": ["./src/types/*"],
            "@models/*": ["./src/models/*"]
        }
    },
    "include": ["src/**/*"]
}
