{
    "manifest_version": 1,
    "type": "WebApp",
    "meta": {
        "name": "Luminux",
        "author": "lunatine",
        "version": "0.0.1",
        "minimum-overwolf-version": "0.170.0",
        "description": "Intergration with the Luminux website for in game live integration with various applications",
        "dock_button_title": "Luminux",
        "icon": "logos/luminux_256x256_v2.png",
        "icon_gray": "logos/luminux_256x256_v2.png",
        "launcher_icon": "logos/luminux_256x256.ico",
        "splash_image": "logos/luminux_256x256_v2.png",
        "window_icon": "logos/luminux_256x256_v2.png"
    },

    "permissions": ["GameInfo", "Tray"],

    "data": {
        "start_window": "background",
        "windows": {
            "background": {
                "file": "background.html",
                "background_optimization": true,
                "is_background_page": true
            },
            "main": {
                "file": "index.html",
                "desktop_only": true,
                "configurable_magnification": true,
                "size": {
                    "width": 400,
                    "height": 500
                },
                "show_in_taskbar": true,
                "native_window": false,
                "transparent": true
            }
        },
        "game_targeting": {
            "type": "dedicated",
            "game_ids": [10844]
        },
        "game_events": [10844],
        "launch_events": [
            {
                "event": "GameLaunch",
                "event_data": {
                    "game_ids": [10844]
                },
                "start_window": "background"
            }
        ],
        "developer": {
            "enable_auto_refresh": true,
            "reload_delay": 1000,
            "filter": "*.*"
        }
    }
}
