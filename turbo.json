{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [".svelte-kit/**", "dist/**", "build/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "sync:api": {
            "cache": false
        }
    }
}
